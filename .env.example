# Local direct mode: Eureka/Discovery off.
# spring.profiles.active=local-direct

# Gateway/Eureka mode.
# spring.profiles.active=local

STOCK_BATCH_INTERNAL_TOKEN=local-stock-batch-internal-token
STOCK_BATCH_SERVER_SHUTDOWN=graceful
STOCK_BATCH_SHUTDOWN_TIMEOUT=70s
STOCK_BATCH_SCHEDULING_AWAIT_TERMINATION=true
STOCK_BATCH_SCHEDULING_AWAIT_TERMINATION_PERIOD=60s
STOCK_BATCH_SHUTDOWN_AWAIT_RUNNING_JOBS_SECONDS=60
STOCK_BATCH_MARKET_DATA_ENABLED=true
STOCK_BATCH_MARKET_DATA_PROVIDER=mock
STOCK_BATCH_ORDER_BOOK_EXECUTION_ENABLED=true
STOCK_BATCH_ORDER_BOOK_EXECUTION_INITIAL_DELAY_MS=36000
STOCK_BATCH_ORDER_BOOK_EXECUTION_FIXED_DELAY_MS=30000
STOCK_BATCH_CORPORATE_ACTIONS_ENABLED=true
STOCK_BATCH_CORPORATE_ACTIONS_INITIAL_DELAY_MS=20000
STOCK_BATCH_CORPORATE_ACTIONS_FIXED_DELAY_MS=60000
STOCK_BATCH_CORPORATE_ACTION_ACCOUNT_CHUNK_SIZE=200
STOCK_BATCH_CORPORATE_ACTION_ACTION_BATCH_LIMIT=25
STOCK_BATCH_AUTO_MARKET_ENABLED=true
STOCK_BATCH_AUTO_MARKET_INITIAL_DELAY_MS=5000
# The active dispatcher is fixed-rate and rejects values below 5000ms so a
# copied example cannot create an order-generation storm or fail startup.
STOCK_BATCH_AUTO_MARKET_FIXED_RATE_MS=5000

# EOD polling only discovers eligible work. Correctness comes from the DB
# session fence/cycle claim, and durable retry windows prevent every poll from
# launching another Spring Batch execution after a failure.
STOCK_BATCH_MARKET_CLOSE_POLL_FIXED_DELAY_MS=10000
STOCK_BATCH_MARKET_CLOSE_ORDER_CAPTURE_CHUNK_SIZE=1000
STOCK_BATCH_MARKET_CLOSE_ORDER_CANCEL_CHUNK_SIZE=500
STOCK_BATCH_MARKET_CLOSE_HOLDING_SNAPSHOT_ACCOUNT_CHUNK_SIZE=500
STOCK_BATCH_MARKET_CLOSE_ACCOUNT_SNAPSHOT_CHUNK_SIZE=500
STOCK_BATCH_MARKET_CLOSE_RECONCILIATION_ACCOUNT_CHUNK_SIZE=500
STOCK_BATCH_MARKET_CLOSE_SETTLEMENT_DELAY_SIMULATION_MINUTES=10
STOCK_BATCH_POST_CLOSE_COORDINATOR_ENABLED=true
STOCK_BATCH_POST_CLOSE_COORDINATOR_POLL_FIXED_DELAY_MS=10000
STOCK_BATCH_POST_CLOSE_LEASE_SECONDS=180
STOCK_BATCH_POST_CLOSE_RETRY_BASE_SECONDS=30
STOCK_BATCH_POST_CLOSE_RETRY_MAX_SECONDS=900
STOCK_BATCH_POST_CLOSE_DEFERRED_RETRY_SECONDS=60
STOCK_BATCH_POST_CLOSE_PREOPEN_TRANSFORM_TIME=04:30
STOCK_BATCH_POST_CLOSE_AUTO_MARKET_PREPARATION_TIME=05:30
STOCK_BATCH_POST_CLOSE_READINESS_TIME=05:30
STOCK_BATCH_POST_CLOSE_REPORT_AGGREGATION_SYMBOL_CHUNK_SIZE=25
# Metadata retention is a compact archive of completed Spring Batch executions.
# Keep both switches false until the metadata-only DDL has been applied and an
# operator has approved retention days plus an explicit purge job allow-list.
STOCK_BATCH_METADATA_RETENTION_ENABLED=false
STOCK_BATCH_METADATA_RETENTION_REAL_DAYS=30
STOCK_BATCH_METADATA_RETENTION_INSTANCE_LIMIT=25
STOCK_BATCH_METADATA_RETENTION_MAX_EXECUTIONS_PER_INSTANCE=20
STOCK_BATCH_METADATA_RETENTION_MAX_STEPS_PER_INSTANCE=200
STOCK_BATCH_METADATA_RETENTION_PURGE_ENABLED=false
STOCK_BATCH_METADATA_RETENTION_PURGE_JOB_NAMES=
STOCK_BATCH_SETTLEMENT_ENABLED=true
STOCK_BATCH_SETTLEMENT_CHUNK_SIZE=200
STOCK_BATCH_SIGNAL_CHUNK_LIMIT=20
STOCK_BATCH_SIGNAL_LEASE_SECONDS=180
STOCK_BATCH_SIGNAL_HEARTBEAT_INTERVAL_SECONDS=30
STOCK_PRICE_CACHE_TTL_SECONDS=60

KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_MARKET_DIV_CODE=J
