# Local direct mode: Eureka/Discovery off.
# spring.profiles.active=local-direct

# Gateway/Eureka mode.
# spring.profiles.active=local

STOCK_BATCH_INTERNAL_TOKEN=local-stock-batch-internal-token
STOCK_BATCH_SERVER_SHUTDOWN=graceful
STOCK_BATCH_SHUTDOWN_TIMEOUT=70s
STOCK_BATCH_SCHEDULING_AWAIT_TERMINATION=true
STOCK_BATCH_SCHEDULING_AWAIT_TERMINATION_PERIOD=60s
STOCK_BATCH_SHUTDOWN_AWAIT_RUNNING_JOBS_SECONDS=60
STOCK_BATCH_MARKET_DATA_ENABLED=true
STOCK_BATCH_MARKET_DATA_PROVIDER=mock
STOCK_BATCH_VIRTUAL_PRICE_EXECUTION_ENABLED=true
STOCK_BATCH_VIRTUAL_PRICE_EXECUTION_INITIAL_DELAY_MS=35000
STOCK_BATCH_VIRTUAL_PRICE_EXECUTION_FIXED_DELAY_MS=5000
STOCK_BATCH_ORDER_BOOK_EXECUTION_ENABLED=true
STOCK_BATCH_ORDER_BOOK_EXECUTION_INITIAL_DELAY_MS=36000
STOCK_BATCH_ORDER_BOOK_EXECUTION_FIXED_DELAY_MS=1000
STOCK_BATCH_CORPORATE_ACTIONS_ENABLED=true
STOCK_BATCH_CORPORATE_ACTIONS_INITIAL_DELAY_MS=20000
STOCK_BATCH_CORPORATE_ACTIONS_FIXED_DELAY_MS=60000
STOCK_BATCH_AUTO_MARKET_ENABLED=true
STOCK_BATCH_AUTO_MARKET_INITIAL_DELAY_MS=5000
STOCK_BATCH_AUTO_MARKET_FIXED_DELAY_MS=1000
STOCK_BATCH_SETTLEMENT_CRON=0 40 15 * * MON-FRI
STOCK_BATCH_SETTLEMENT_ZONE=Asia/Seoul
STOCK_PRICE_CACHE_TTL_SECONDS=60

KIS_BASE_URL=https://openapi.koreainvestment.com:9443
KIS_APP_KEY=
KIS_APP_SECRET=
KIS_MARKET_DIV_CODE=J
